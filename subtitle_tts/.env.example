API2KEY_BASE_URL=https://stage.api2key.com
# Subtitle TTS demo environment
# Usage from repo root:
# set -a
# source ./subtitle_tts/.env.example
# set +a
# go run ./subtitle_tts

API2KEY_BASE_URL=https://stage.api2key.com

# Required for login flow when API2KEY_API_KEY is empty.
API2KEY_EMAIL=your-email@example.com
API2KEY_PASSWORD=your-password
API2KEY_PROJECT_ID=your-project-id

# Optional: if set, the demo skips login and uses this key directly.
API2KEY_API_KEY=

# Optional: used by EnsureAPIKey after login.
API2KEY_KEY_NAME=subtitle-tts

# Optional TTS settings.
API2KEY_PROVIDER=auto
API2KEY_SEARCH=
API2KEY_VOICE=zh-CN-XiaoxiaoNeural
API2KEY_LOCALE=zh-CN
API2KEY_FORMAT=audio-24khz-96kbitrate-mono-mp3
API2KEY_RATE=1
API2KEY_VOLUME=100
API2KEY_PITCH=0

# Input / output settings.
API2KEY_INPUT=./subtitle_tts/001.srt
API2KEY_OUTPUT=./subtitle_tts/output
API2KEY_PREFIX=segment_
API2KEY_VIDEO_ID=subtitle-demo